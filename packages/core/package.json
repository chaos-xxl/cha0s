{
  "name": "@doctorchaos-ai/core",
  "version": "0.1.0-alpha.0",
  "description": "Doctor Chaos — the conversation organization layer for AI chat apps. Routing, clustering, and lifecycle for self-organising conversations.",
  "keywords": [
    "ai",
    "conversation",
    "chat",
    "llm",
    "routing",
    "clustering",
    "topic",
    "organization",
    "doctor-chaos"
  ],
  "author": "Chaos <chaosxinglong@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/doctorchaos-ai/doctor-chaos",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/doctorchaos-ai/doctor-chaos.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/doctorchaos-ai/doctor-chaos/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"No lint configured yet\" && exit 0",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "vitest": "^2.1.8"
  }
}

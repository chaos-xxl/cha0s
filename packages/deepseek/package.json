{
  "name": "@doctorchaos-ai/deepseek",
  "version": "0.1.0-alpha.0",
  "description": "DeepSeek LLM adapter for Doctor Chaos — route conversations with deepseek-chat, deepseek-reasoner, and friends.",
  "keywords": [
    "ai",
    "doctor-chaos",
    "deepseek",
    "llm",
    "routing",
    "adapter"
  ],
  "author": "Chaos <chaosxinglong@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/doctorchaos-ai/doctor-chaos",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/doctorchaos-ai/doctor-chaos.git",
    "directory": "packages/deepseek"
  },
  "bugs": {
    "url": "https://github.com/doctorchaos-ai/doctor-chaos/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"No lint configured yet\" && exit 0",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@doctorchaos-ai/core": "workspace:*"
  },
  "devDependencies": {
    "@doctorchaos-ai/core": "workspace:*",
    "tsup": "^8.3.5",
    "vitest": "^2.1.8"
  }
}

{
  "name": "@cha0s-ai/openai",
  "version": "0.1.0-alpha.0",
  "description": "OpenAI embedding adapter for cha0s — swap keyword matching for semantic routing with one line.",
  "keywords": [
    "ai",
    "cha0s",
    "openai",
    "embeddings",
    "semantic-routing",
    "conversation",
    "adapter"
  ],
  "author": "Chaos <chaosxinglong@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/chaos-xxl/cha0s",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chaos-xxl/cha0s.git",
    "directory": "packages/openai"
  },
  "bugs": {
    "url": "https://github.com/chaos-xxl/cha0s/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"No lint configured yet\" && exit 0",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@cha0s-ai/core": "workspace:*"
  },
  "devDependencies": {
    "@cha0s-ai/core": "workspace:*",
    "tsup": "^8.3.5",
    "vitest": "^2.1.8"
  }
}

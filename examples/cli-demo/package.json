{
  "name": "@doctorchaos-ai/cli-demo",
  "version": "0.1.0-alpha.0",
  "description": "Interactive terminal demo showing Doctor Chaos auto-organising a conversation in real time.",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "doctor-chaos-demo": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "start": "pnpm build && node dist/index.js",

    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@doctorchaos-ai/core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18"
  },
